# ============================================
# ENVIRONMENT VARIABLES - COPY TO .env
# ============================================
# DO NOT COMMIT .env FILE (add to .gitignore)
# COPY THIS FILE AND RENAME TO .env

# ============================================
# FRONTEND CONFIGURATION
# ============================================
# API URL for frontend to call backend
REACT_APP_API_URL=http://localhost:3000
VITE_API_URL=http://localhost:3000

# ============================================
# BACKEND CONFIGURATION
# ============================================
PORT=3000
NODE_ENV=development

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5000

# ============================================
# JWT/SECURITY
# ============================================
# Generate a secure string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production-12345

# ============================================
# MYSQL DATABASE
# ============================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=camera_store

# ============================================
# SQLITE DATABASE (local development)
# ============================================
SQLITE_PATH=./data/store.db

# ============================================
# EMAIL/NODEMAILER CONFIGURATION
# ============================================
# Gmail: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
EMAIL_FROM=Camera Store <noreply@camerastore.com>
EMAIL_SUPPORT=support@camerastore.com

# ============================================
# OPTIONAL: PAYMENT/COMMERCE APIs
# ============================================
# STRIPE_SECRET_KEY=your_stripe_secret_key
# STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
# PAYPAL_CLIENT_ID=your_paypal_client_id

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug
